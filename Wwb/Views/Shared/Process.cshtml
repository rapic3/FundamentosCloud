                <div class="code-block">
                    <pre>
using System.Threading.Tasks;
using Microsoft.AspNetCore.Mvc;
using Negocio.Interfaces;
using Repositorio.Dominio;

namespace Wwb.Controllers
{
    public class UsersController : Controller
    {
        private readonly IUserNegocio _UserNegocio;

        public UsersController(IUserNegocio UserNegocio)
        {
            _UserNegocio = UserNegocio;
        }

        public async Task&lt;IActionResult&gt; Index()
        {
            var users = await _UserNegocio.GetAllUsersAsync();
            return View(users);
        }

        public IActionResult Create()
        {
            return View();
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task&lt;IActionResult&gt; Create([Bind("Id,Name,LastName,Phone,Age")] User user)
        {
            if (ModelState.IsValid)
            {
                await _UserNegocio.CreateUserAsync(user);
                return RedirectToAction(nameof(Index));
            }
            return View(user);
        }

        public async Task&lt;IActionResult&gt; Edit(string id)
        {
            var user = await _UserNegocio.GetUserByIdAsync(id);
            if (user == null)
            {
                return NotFound();
            }
            return View(user);
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task&lt;IActionResult&gt; Edit(string id, [Bind("Id,Name,LastName,Phone,Age")] User user)
        {
            if (id != user.Id)
            {
                return NotFound();
            }

            if (ModelState.IsValid)
            {
                await _UserNegocio.UpdateUserAsync(user);
                return RedirectToAction(nameof(Index));
            }
            return View(user);
        }

        public async Task&lt;IActionResult&gt; Delete(string id)
        {
            var user = await _UserNegocio.GetUserByIdAsync(id);
            if (user == null)
            {
                return NotFound();
            }
            return View(user);
        }

        [HttpPost, ActionName("Delete")]
        [ValidateAntiForgeryToken]
        public async Task&lt;IActionResult&gt; DeleteConfirmed(string id)
        {
            await _UserNegocio.DeleteUserAsync(id);
            return RedirectToAction(nameof(Index));
        }
    }
}
