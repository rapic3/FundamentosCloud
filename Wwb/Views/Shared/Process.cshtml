                <div class="step-title">Implementación UsuarioRepositorio</div>
                <div class="file-path">Repositorio/UsuarioRepositorio.cs</div>
                <div class="code-block">
                    <pre>
using System.Collections.Generic;
using System.Threading.Tasks;
using Google.Cloud.Firestore;
using Repositorio.Dominio;
using Repositorio.Interfaces;

namespace Repositorio
{
    public class UsuarioRepositorio : IUsuarioRepositorio
    {
        private readonly FirestoreDb _firestoreDb;

        public UsuarioRepositorio()
        {
            FirebaseService.Initialize();
            _firestoreDb = FirestoreDb.Create("tu-id-de-proyecto");
        }

        public async Task&lt;List&lt;User&gt;&gt; GetAllUsersAsync()
        {
            var usersRef = _firestoreDb.Collection("users");
            var snapshot = await usersRef.GetSnapshotAsync();
            var users = new List&lt;User&gt;();
            
            foreach (var document in snapshot.Documents)
            {
                users.Add(document.ConvertTo&lt;User&gt;());
            }
            return users;
        }

        public async Task&lt;User&gt; GetUserByIdAsync(string id)
        {
            var userDoc = _firestoreDb.Collection("users").Document(id);
            var snapshot = await userDoc.GetSnapshotAsync();
            return snapshot.Exists ? snapshot.ConvertTo&lt;User&gt;() : null;
        }

        public async Task CreateUserAsync(User user)
        {
            var userRef = _firestoreDb.Collection("users").Document(user.Id);
            await userRef.SetAsync(user);
        }

        public async Task UpdateUserAsync(User user)
        {
            var userRef = _firestoreDb.Collection("users").Document(user.Id);
            await userRef.SetAsync(user, SetOptions.MergeAll);
        }

        public async Task DeleteUserAsync(string id)
        {
            var userRef = _firestoreDb.Collection("users").Document(id);
            await userRef.DeleteAsync();
        }
    }
}
