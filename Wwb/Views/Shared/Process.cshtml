                    <pre>
using FirebaseAdmin;
using Google.Apis.Auth.OAuth2;
using System.IO;

namespace Repositorio
{
    public static class FirebaseService
    {
        public static void Initialize()
        {
            if (FirebaseApp.DefaultInstance == null)
            {
                var jsonCredentials = File.ReadAllText("google-services.json");
                FirebaseApp.Create(new AppOptions()
                {
                    Credential = GoogleCredential.FromJson(jsonCredentials),
                    ProjectId = "tu-id-de-proyecto"
                });
            }
        }
    }
}
                    </pre>
                </div>
                <div class="note">
                    <p><strong>Nota:</strong> Asegúrate de que el archivo <code>google-services.json</code> esté marcado como <code>Copiar en el directorio de salida</code>.</p>
